// Inclusive/exclusive ranges, while loops, compound assignment.
func main() -> void {
    int32 sum = 0
    for (i in 0..5) {
        sum += i
    }
    println("{sum}")
    int32 count = 0
    for (j in 0..<5) {
        count += 1
    }
    println("{count}")
    int32 n = 1
    while (n < 100) {
        n *= 2
    }
    println("{n}")
}
