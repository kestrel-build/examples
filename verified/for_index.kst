// for (i, item in arr) — iterate with both index and value.
func main() -> void {
    str[3] fruits = ["apple", "berry", "cherry"]
    for (i, name in fruits) {
        println("{i}: {name}")
    }
    int32[3] nums = [10, 20, 30]
    int32 sum = 0
    for (i, n in nums) {
        sum += i
        sum += n
    }
    println("sum = {sum}")
}
